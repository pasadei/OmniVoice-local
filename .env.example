# OmniVoice TTS Server — Environment Configuration
# Copy this file to .env and adjust values as needed.
# When using Docker Compose, variables can also be set directly in compose.yaml.

# ---------------------------------------------------------------------------
# Model
# ---------------------------------------------------------------------------
OMNIVOICE_MODEL=k2-fsa/OmniVoice
# For a pre-downloaded local model (see README for setup):
# OMNIVOICE_MODEL=/models/OmniVoice

# ---------------------------------------------------------------------------
# Inference
# ---------------------------------------------------------------------------
OMNIVOICE_DEVICE=cuda:0
OMNIVOICE_DTYPE=float16

# ---------------------------------------------------------------------------
# Samples
# ---------------------------------------------------------------------------
OMNIVOICE_SAMPLES_DIR=/samples

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
OMNIVOICE_HOST=0.0.0.0
OMNIVOICE_PORT=8000
OMNIVOICE_OUTPUT_FORMAT=wav

# ---------------------------------------------------------------------------
# Gradio Web UI
# ---------------------------------------------------------------------------
OMNIVOICE_GRADIO_ENABLED=true
OMNIVOICE_GRADIO_PORT=8001

# ---------------------------------------------------------------------------
# Authentication (optional)
# ---------------------------------------------------------------------------
# When set, all API endpoints except GET /health require:
#   Authorization: Bearer <your-key>
# Leave empty or remove entirely to disable authentication.
# OMNIVOICE_API_KEY=change-me-to-a-strong-secret
