# OmniVoice TTS Server — Environment Configuration
# All settings are configured directly in compose.yaml.
# The only value that belongs here is the API key secret.

# ---------------------------------------------------------------------------
# Authentication (optional)
# ---------------------------------------------------------------------------
# When set, all API endpoints except GET /health require:
#   Authorization: Bearer <your-key>
# Leave empty or remove entirely to disable authentication.
# OMNIVOICE_API_KEY=change-me-to-a-strong-secret
